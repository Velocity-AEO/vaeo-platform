{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build:worker": "esbuild scripts/crawl-worker.ts --bundle --platform=node --format=esm --packages=external --outfile=scripts/dist/crawl-worker.mjs",
