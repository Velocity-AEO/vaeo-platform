{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "paths": {
      "@supabase/supabase-js": ["./apps/dashboard/node_modules/@supabase/supabase-js"],
      "@anthropic-ai/sdk": ["./apps/dashboard/node_modules/@anthropic-ai/sdk"],
      "@tools/*": ["./tools/*"]
    }
  },
  "include": ["tools/**/*.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "apps/dashboard"]
}
